{
	"compilerOptions": {
		"target": "ES2022",
		"module": "ES2022",
		"moduleResolution": "bundler",
		"strict": true,
		"skipLibCheck": true,
		"esModuleInterop": true,
		"forceConsistentCasingInFileNames": true,
		"resolveJsonModule": true,
		"declaration": true,
		"declarationMap": true,
		"sourceMap": true,
		"experimentalDecorators": true,
		"emitDecoratorMetadata": true,
		"types": ["@types/bun"]
	},
	"references": [
		{ "path": "packages/shared" },
		{ "path": "packages/client" },
		{ "path": "packages/core" },
		{ "path": "packages/sync" },
		{ "path": "packages/sandbox" },
		{ "path": "packages/llm" },
		{ "path": "packages/agent" },
		{ "path": "packages/web" },
		{ "path": "packages/platforms" }
	]
}
